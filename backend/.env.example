# Database
DATABASE_URL=postgresql+asyncpg://cnvn:cnvn_secret@db:5432/cnvn

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
